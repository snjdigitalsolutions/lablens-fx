<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>


<fx:root maxHeight="1.7976931348623157E308" type="GridPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
    <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" prefWidth="100.0" />
  </columnConstraints>
  <rowConstraints>
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
      <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
  </rowConstraints>
   <children>
      <Label text="Hostname:" />
      <Label text="IP Address:" GridPane.rowIndex="1" />
      <Label text="OS: " GridPane.rowIndex="2" />
      <Label text="Description:" GridPane.rowIndex="3" />
      <Label fx:id="hostNameLabel" text="Label" GridPane.columnIndex="1" />
      <Label fx:id="ipAddressLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      <Label fx:id="osLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      <Label fx:id="descriptionLabel" maxHeight="1.7976931348623157E308" text="Label" wrapText="true" GridPane.columnSpan="2" GridPane.rowIndex="4" />
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</fx:root>
